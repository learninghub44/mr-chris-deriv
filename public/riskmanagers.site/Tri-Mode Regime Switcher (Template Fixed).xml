<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="tm_stake">Stake</variable>
    <variable id="tm_sequence_step">Sequence Step</variable>
    <variable id="tm_signal">Sequence Signal</variable>
    <variable id="tm_contract_type">Contract Type</variable>
    <variable id="tm_prediction">Prediction</variable>
    <variable id="tm_duration">Duration</variable>
  </variables>
  <block type="trade_definition" id="tm_trade_definition" deletable="false" x="24" y="40">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="tm_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ10V</field>
        <next>
          <block type="trade_definition_tradetype" id="tm_trade_type" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">overunder</field>
            <next>
              <block type="trade_definition_contracttype" id="tm_contract_family" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="tm_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="tm_restart_buy_sell" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="tm_restart_error" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="tm_init_stake">
        <field name="VAR" id="tm_stake">Stake</field>
        <value name="VALUE">
          <block type="math_number" id="tm_init_stake_value">
            <field name="NUM">1</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="tm_init_sequence_step">
            <field name="VAR" id="tm_sequence_step">Sequence Step</field>
            <value name="VALUE">
              <block type="math_number" id="tm_init_sequence_step_value">
                <field name="NUM">0</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="tm_init_signal">
                <field name="VAR" id="tm_signal">Sequence Signal</field>
                <value name="VALUE">
                  <block type="math_number" id="tm_init_signal_value">
                    <field name="NUM">0</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="tm_init_contract">
                    <field name="VAR" id="tm_contract_type">Contract Type</field>
                    <value name="VALUE">
                      <block type="text" id="tm_init_contract_value">
                        <field name="TEXT">DIGITOVER</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="tm_init_prediction">
                        <field name="VAR" id="tm_prediction">Prediction</field>
                        <value name="VALUE">
                          <block type="math_number" id="tm_init_prediction_value">
                            <field name="NUM">4</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="tm_init_duration">
                            <field name="VAR" id="tm_duration">Duration</field>
                            <value name="VALUE">
                              <block type="math_number" id="tm_init_duration_value">
                                <field name="NUM">1</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="tm_trade_options">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <shadow type="math_number_positive" id="tm_trade_duration_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="variables_get" id="tm_trade_duration">
            <field name="VAR" id="tm_duration">Duration</field>
          </block>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number_positive" id="tm_trade_amount_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="variables_get" id="tm_trade_amount">
            <field name="VAR" id="tm_stake">Stake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <shadow type="math_number_positive" id="tm_trade_prediction_shadow">
            <field name="NUM">4</field>
          </shadow>
          <block type="variables_get" id="tm_trade_prediction">
            <field name="VAR" id="tm_prediction">Prediction</field>
          </block>
        </value>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="tm_before_purchase" deletable="false" x="24" y="570">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="variables_set" id="tm_set_signal">
        <field name="VAR" id="tm_signal">Sequence Signal</field>
        <value name="VALUE">
          <block type="tri_mode_regime_signal" id="tm_regime_analysis">
            <value name="HISTORY">
              <shadow type="math_number" id="tm_analysis_history">
                <field name="NUM">100</field>
              </shadow>
            </value>
            <value name="SEQUENCE_STEP">
              <block type="variables_get" id="tm_analysis_sequence_step">
                <field name="VAR" id="tm_sequence_step">Sequence Step</field>
              </block>
            </value>
          </block>
        </value>
        <next>
          <block type="controls_if" id="tm_has_signal">
            <value name="IF0">
              <block type="logic_compare" id="tm_signal_is_valid">
                <field name="OP">GT</field>
                <value name="A">
                  <block type="variables_get" id="tm_signal_check">
                    <field name="VAR" id="tm_signal">Sequence Signal</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="tm_zero_signal">
                    <field name="NUM">0</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="variables_set" id="tm_set_contract">
                <field name="VAR" id="tm_contract_type">Contract Type</field>
                <value name="VALUE">
                  <block type="tri_mode_signal_value" id="tm_contract_from_signal">
                    <field name="VALUE_TYPE">CONTRACT</field>
                    <value name="SIGNAL">
                      <block type="variables_get" id="tm_contract_signal">
                        <field name="VAR" id="tm_signal">Sequence Signal</field>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="tm_set_prediction">
                    <field name="VAR" id="tm_prediction">Prediction</field>
                    <value name="VALUE">
                      <block type="tri_mode_signal_value" id="tm_prediction_from_signal">
                        <field name="VALUE_TYPE">PREDICTION</field>
                        <value name="SIGNAL">
                          <block type="variables_get" id="tm_prediction_signal">
                            <field name="VAR" id="tm_signal">Sequence Signal</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="tm_set_duration">
                        <field name="VAR" id="tm_duration">Duration</field>
                        <value name="VALUE">
                          <block type="tri_mode_signal_value" id="tm_duration_from_signal">
                            <field name="VALUE_TYPE">DURATION</field>
                            <value name="SIGNAL">
                              <block type="variables_get" id="tm_duration_signal">
                                <field name="VAR" id="tm_signal">Sequence Signal</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <next>
                          <block type="smart_purchase_contract" id="tm_dynamic_purchase">
                            <field name="DURATIONTYPE_LIST">t</field>
                            <value name="CONTRACT_TYPE">
                              <block type="variables_get" id="tm_purchase_contract">
                                <field name="VAR" id="tm_contract_type">Contract Type</field>
                              </block>
                            </value>
                            <value name="AMOUNT">
                              <block type="variables_get" id="tm_purchase_amount">
                                <field name="VAR" id="tm_stake">Stake</field>
                              </block>
                            </value>
                            <value name="DURATION">
                              <block type="variables_get" id="tm_purchase_duration">
                                <field name="VAR" id="tm_duration">Duration</field>
                              </block>
                            </value>
                            <value name="PREDICTION">
                              <block type="variables_get" id="tm_purchase_prediction">
                                <field name="VAR" id="tm_prediction">Prediction</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="tm_after_purchase" x="780" y="40">
    <statement name="AFTERPURCHASE_STACK">
      <block type="variables_set" id="tm_advance_sequence">
        <field name="VAR" id="tm_sequence_step">Sequence Step</field>
        <value name="VALUE">
          <block type="math_arithmetic" id="tm_increment_sequence">
            <field name="OP">ADD</field>
            <value name="A">
              <block type="variables_get" id="tm_current_sequence_step">
                <field name="VAR" id="tm_sequence_step">Sequence Step</field>
              </block>
            </value>
            <value name="B">
              <block type="math_number" id="tm_sequence_increment">
                <field name="NUM">1</field>
              </block>
            </value>
          </block>
        </value>
        <next>
          <block type="trade_again" id="tm_trade_again"></block>
        </next>
      </block>
    </statement>
  </block>
</xml>
