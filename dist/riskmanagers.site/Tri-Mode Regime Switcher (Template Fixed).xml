                          <block type="match_differ_percentage" id="before_differs_signal_pct">
                            <field name="MODE">differ</field>
                            <value name="DIGIT">
                              <block type="variables_get" id="before_trigger_digit_get">
                                <field name="VAR" id="v_trigger_digit">Trigger Digit</field>
                              </block>
                            </value>
                            <value name="COUNT">
                              <shadow type="math_number" id="before_differs_count_shadow">
                                <field name="NUM">100</field>
                              </shadow>
                            </value>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="before_differs_threshold">
                            <field name="NUM">86</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO3">
                      <block type="variables_set" id="before_differs_cooldown">
                        <field name="VAR" id="v_cooldown">Cooldown</field>
                        <value name="VALUE">
                          <block type="math_number" id="before_differs_cooldown_num">
                            <field name="NUM">5</field>
                          </block>
                        </value>
                        <next>
                          <block type="notify" id="before_differs_notify">
                            <field name="NOTIFICATION_TYPE">info</field>
                            <field name="NOTIFICATION_SOUND">silent</field>
                            <value name="MESSAGE">
                              <block type="text" id="before_differs_text">
                                <field name="TEXT">Differs regime detected. Compatibility build skips cross-family trade and enters cooldown.</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <value name="IF4">
                      <block type="logic_operation" id="before_under_entry_check">
                        <field name="OP">AND</field>
                        <value name="A">
                          <block type="logic_compare" id="before_under_bias_check">
                            <field name="OP">GTE</field>
                            <value name="A">
                              <block type="over_under_percentage" id="before_under_bias_pct">
                                <field name="CONDITION">over</field>
                                <value name="DIGIT">
                                  <shadow type="math_number" id="before_under_digit_shadow">
                                    <field name="NUM">4</field>
                                  </shadow>
                                </value>
                                <value name="COUNT">
                                  <shadow type="math_number" id="before_under_count_shadow">
                                    <field name="NUM">100</field>
                                  </shadow>
                                </value>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="before_under_threshold">
                                <field name="NUM">58</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <value name="B">
                          <block type="logic_compare" id="before_under_skip_window_check">
                            <field name="OP">GTE</field>
                            <value name="A">
                              <block type="variables_get" id="before_current_tick_for_under_check">
                                <field name="VAR" id="v_current_tick">Current Tick</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="before_skip_under_until_get">
                                <field name="VAR" id="v_skip_under_until">Skip Under Until</field>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO4">
                      <block type="variables_set" id="before_set_under_prediction">
                        <field name="VAR" id="v_prediction">Prediction</field>
                        <value name="VALUE">
                          <block type="math_number" id="before_set_under_prediction_num">
                            <field name="NUM">4</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="before_set_under_mode">
                            <field name="VAR" id="v_current_mode">Current Mode</field>
                            <value name="VALUE">
                              <block type="math_number" id="before_set_under_mode_num">
                                <field name="NUM">1</field>
                              </block>
                            </value>
                            <next>
                              <block type="purchase" id="before_purchase_under">
                                <field name="PURCHASE_LIST">DIGITUNDER</field>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <value name="IF5">
                      <block type="logic_operation" id="before_over_entry_check">
                        <field name="OP">AND</field>
                        <value name="A">
                          <block type="logic_compare" id="before_over_bias_check">
                            <field name="OP">GTE</field>
                            <value name="A">
                              <block type="over_under_percentage" id="before_over_bias_pct">
                                <field name="CONDITION">under</field>
                                <value name="DIGIT">
                                  <shadow type="math_number" id="before_over_digit_shadow">
                                    <field name="NUM">4</field>
                                  </shadow>
                                </value>
                                <value name="COUNT">
                                  <shadow type="math_number" id="before_over_count_shadow">
                                    <field name="NUM">100</field>
                                  </shadow>
                                </value>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="before_over_threshold">
                                <field name="NUM">58</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <value name="B">
                          <block type="logic_compare" id="before_over_skip_window_check">
                            <field name="OP">GTE</field>
                            <value name="A">
                              <block type="variables_get" id="before_current_tick_for_over_check">
                                <field name="VAR" id="v_current_tick">Current Tick</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="before_skip_over_until_get">
                                <field name="VAR" id="v_skip_over_until">Skip Over Until</field>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO5">
                      <block type="variables_set" id="before_set_over_prediction">
                        <field name="VAR" id="v_prediction">Prediction</field>
                        <value name="VALUE">
                          <block type="math_number" id="before_set_over_prediction_num">
                            <field name="NUM">4</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="before_set_over_mode">
                            <field name="VAR" id="v_current_mode">Current Mode</field>
                            <value name="VALUE">
                              <block type="math_number" id="before_set_over_mode_num">
                                <field name="NUM">2</field>
                              </block>
                            </value>
                            <next>
                              <block type="purchase" id="before_purchase_over">
                                <field name="PURCHASE_LIST">DIGITOVER</field>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <statement name="ELSE">
                      <block type="controls_if" id="before_trend_fallback_check">
                        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                        <value name="IF0">
                          <block type="logic_operation" id="before_trend_fallback_or">
                            <field name="OP">OR</field>
                            <value name="A">
                              <block type="logic_compare" id="before_rise_trend_check">
                                <field name="OP">GTE</field>
                                <value name="A">
                                  <block type="rise_fall_percentage" id="before_rise_trend_pct">
                                    <field name="DIRECTION">rise</field>
                                    <value name="COUNT">
                                      <shadow type="math_number" id="before_rise_trend_count_shadow">
                                        <field name="NUM">4</field>
                                      </shadow>
                                    </value>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="math_number" id="before_rise_trend_threshold">
                                    <field name="NUM">75</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                            <value name="B">
                              <block type="logic_compare" id="before_fall_trend_check">
                                <field name="OP">GTE</field>
                                <value name="A">
                                  <block type="rise_fall_percentage" id="before_fall_trend_pct">
                                    <field name="DIRECTION">fall</field>
                                    <value name="COUNT">
                                      <shadow type="math_number" id="before_fall_trend_count_shadow">
                                        <field name="NUM">4</field>
                                      </shadow>
                                    </value>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="math_number" id="before_fall_trend_threshold">
                                    <field name="NUM">75</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="variables_set" id="before_trend_cooldown">
                            <field name="VAR" id="v_cooldown">Cooldown</field>
                            <value name="VALUE">
                              <block type="math_number" id="before_trend_cooldown_num">
                                <field name="NUM">5</field>
                              </block>
                            </value>
                            <next>
                              <block type="notify" id="before_trend_notify">
                                <field name="NOTIFICATION_TYPE">info</field>
                                <field name="NOTIFICATION_SOUND">silent</field>
                                <value name="MESSAGE">
                                  <block type="text" id="before_trend_text">
                                    <field name="TEXT">Rise/Fall regime detected. Compatibility build skips cross-family trade and enters cooldown.</field>
                                  </block>
                                </value>
                              </block>
                            </next>
                          </block>
                        </statement>
                        <statement name="ELSE">
                          <block type="variables_set" id="before_no_edge_cooldown">
                            <field name="VAR" id="v_cooldown">Cooldown</field>
                            <value name="VALUE">
                              <block type="math_number" id="before_no_edge_cooldown_num">
                                <field name="NUM">5</field>
                              </block>
                            </value>
                            <next>
                              <block type="notify" id="before_no_edge_notify">
                                <field name="NOTIFICATION_TYPE">warn</field>
                                <field name="NOTIFICATION_SOUND">silent</field>
                                <value name="MESSAGE">
                                  <block type="text" id="before_no_edge_text">
                                    <field name="TEXT">No qualified edge found. Cooldown started.</field>
                                  </block>
                                </value>
                              </block>
                            </next>
                          </block>
                        </statement>
                      </block>
                    </statement>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
