<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="v_start_balance">Start Balance</variable>
    <variable id="v_stake">Stake</variable>
    <variable id="v_stake_pct">Stake %</variable>
    <variable id="v_loss_limit">Loss Limit %</variable>
    <variable id="v_profit_target">Profit Target %</variable>
    <variable id="v_prediction">Prediction</variable>
    <variable id="v_current_tick">Current Tick</variable>
    <variable id="v_cooldown">Cooldown</variable>
    <variable id="v_current_mode">Current Mode</variable>
    <variable id="v_under_loss_streak">Under Loss Streak</variable>
    <variable id="v_over_loss_streak">Over Loss Streak</variable>
    <variable id="v_skip_under_until">Skip Under Until</variable>
    <variable id="v_skip_over_until">Skip Over Until</variable>
    <variable id="v_trigger_digit">Trigger Digit</variable>
  </variables>
  <block type="trade_definition" id="trade_definition_main" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="trade_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ100V</field>
        <next>
          <block type="trade_definition_tradetype" id="trade_type" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">overunder</field>
            <next>
              <block type="trade_definition_contracttype" id="trade_contract" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="trade_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="trade_restart_buy_sell" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="trade_restart_error" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="init_start_balance">
        <field name="VAR" id="v_start_balance">Start Balance</field>
        <value name="VALUE">
          <block type="balance" id="init_balance_value">
            <field name="BALANCE_TYPE">NUM</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="init_stake_pct">
            <field name="VAR" id="v_stake_pct">Stake %</field>
            <value name="VALUE">
              <block type="math_number" id="init_stake_pct_num">
                <field name="NUM">0.0035</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="init_loss_limit">
                <field name="VAR" id="v_loss_limit">Loss Limit %</field>
                <value name="VALUE">
                  <block type="math_number" id="init_loss_limit_num">
                    <field name="NUM">0.1</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="init_profit_target">
                    <field name="VAR" id="v_profit_target">Profit Target %</field>
                    <value name="VALUE">
                      <block type="math_number" id="init_profit_target_num">
                        <field name="NUM">0.05</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="init_prediction">
                        <field name="VAR" id="v_prediction">Prediction</field>
                        <value name="VALUE">
                          <block type="math_number" id="init_prediction_num">
                            <field name="NUM">4</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="init_stake">
                            <field name="VAR" id="v_stake">Stake</field>
                            <value name="VALUE">
                              <block type="math_arithmetic" id="init_stake_calc">
                                <field name="OP">MULTIPLY</field>
                                <value name="A">
                                  <block type="balance" id="init_balance_for_stake">
                                    <field name="BALANCE_TYPE">NUM</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="variables_get" id="init_stake_pct_get">
                                    <field name="VAR" id="v_stake_pct">Stake %</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                            <next>
                              <block type="variables_set" id="init_current_tick">
                                <field name="VAR" id="v_current_tick">Current Tick</field>
                                <value name="VALUE">
                                  <block type="math_number" id="init_current_tick_num">
                                    <field name="NUM">0</field>
                                  </block>
                                </value>
                                <next>
                                  <block type="variables_set" id="init_cooldown">
                                    <field name="VAR" id="v_cooldown">Cooldown</field>
                                    <value name="VALUE">
                                      <block type="math_number" id="init_cooldown_num">
                                        <field name="NUM">0</field>
                                      </block>
                                    </value>
                                    <next>
                                      <block type="variables_set" id="init_current_mode">
                                        <field name="VAR" id="v_current_mode">Current Mode</field>
                                        <value name="VALUE">
                                          <block type="math_number" id="init_current_mode_num">
                                            <field name="NUM">0</field>
                                          </block>
                                        </value>
                                        <next>
                                          <block type="variables_set" id="init_under_loss">
                                            <field name="VAR" id="v_under_loss_streak">Under Loss Streak</field>
                                            <value name="VALUE">
                                              <block type="math_number" id="init_under_loss_num">
                                                <field name="NUM">0</field>
                                              </block>
                                            </value>
                                            <next>
                                              <block type="variables_set" id="init_over_loss">
                                                <field name="VAR" id="v_over_loss_streak">Over Loss Streak</field>
                                                <value name="VALUE">
                                                  <block type="math_number" id="init_over_loss_num">
                                                    <field name="NUM">0</field>
                                                  </block>
                                                </value>
                                                <next>
                                                  <block type="variables_set" id="init_skip_under">
                                                    <field name="VAR" id="v_skip_under_until">Skip Under Until</field>
                                                    <value name="VALUE">
                                                      <block type="math_number" id="init_skip_under_num">
                                                        <field name="NUM">0</field>
                                                      </block>
                                                    </value>
                                                    <next>
                                                      <block type="variables_set" id="init_skip_over">
                                                        <field name="VAR" id="v_skip_over_until">Skip Over Until</field>
                                                        <value name="VALUE">
                                                          <block type="math_number" id="init_skip_over_num">
                                                            <field name="NUM">0</field>
                                                          </block>
                                                        </value>
                                                        <next>
                                                          <block type="variables_set" id="init_trigger_digit">
                                                            <field name="VAR" id="v_trigger_digit">Trigger Digit</field>
                                                            <value name="VALUE">
                                                              <block type="math_number" id="init_trigger_digit_num">
                                                                <field name="NUM">0</field>
                                                              </block>
                                                            </value>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="trade_options_main">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <shadow type="math_number_positive" id="trade_duration_shadow">
            <field name="NUM">1</field>
          </shadow>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number_positive" id="trade_amount_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="variables_get" id="trade_amount_value">
            <field name="VAR" id="v_stake">Stake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <shadow type="math_number_positive" id="trade_prediction_shadow">
            <field name="NUM">4</field>
          </shadow>
          <block type="variables_get" id="trade_prediction_value">
            <field name="VAR" id="v_prediction">Prediction</field>
          </block>
        </value>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="after_purchase_main" x="760" y="60">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="after_is_win">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="after_contract_result">
            <field name="CHECK_RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="controls_if" id="after_win_mode_check">
            <mutation xmlns="http://www.w3.org/1999/xhtml" elseif="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="after_win_under_mode">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="after_win_mode_value">
                    <field name="VAR" id="v_current_mode">Current Mode</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="after_win_under_num">
                    <field name="NUM">1</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="variables_set" id="after_reset_under_streak">
                <field name="VAR" id="v_under_loss_streak">Under Loss Streak</field>
                <value name="VALUE">
                  <block type="math_number" id="after_reset_under_streak_num">
                    <field name="NUM">0</field>
                  </block>
                </value>
              </block>
            </statement>
            <value name="IF1">
              <block type="logic_compare" id="after_win_over_mode">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="after_win_mode_value_over">
                    <field name="VAR" id="v_current_mode">Current Mode</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="after_win_over_num">
                    <field name="NUM">2</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO1">
              <block type="variables_set" id="after_reset_over_streak">
                <field name="VAR" id="v_over_loss_streak">Over Loss Streak</field>
                <value name="VALUE">
                  <block type="math_number" id="after_reset_over_streak_num">
                    <field name="NUM">0</field>
                  </block>
                </value>
              </block>
            </statement>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="controls_if" id="after_loss_mode_check">
            <mutation xmlns="http://www.w3.org/1999/xhtml" elseif="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="after_loss_under_mode">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="after_loss_mode_value">
                    <field name="VAR" id="v_current_mode">Current Mode</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="after_loss_under_num">
                    <field name="NUM">1</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="variables_set" id="after_increment_under_streak">
                <field name="VAR" id="v_under_loss_streak">Under Loss Streak</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="after_increment_under_streak_calc">
                    <field name="OP">ADD</field>
                    <value name="A">
                      <block type="variables_get" id="after_under_streak_get">
                        <field name="VAR" id="v_under_loss_streak">Under Loss Streak</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number" id="after_under_streak_inc">
                        <field name="NUM">1</field>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="controls_if" id="after_under_skip_check">
                    <value name="IF0">
                      <block type="logic_compare" id="after_under_streak_limit">
                        <field name="OP">GTE</field>
                        <value name="A">
                          <block type="variables_get" id="after_under_streak_limit_get">
                            <field name="VAR" id="v_under_loss_streak">Under Loss Streak</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="after_under_streak_limit_num">
                            <field name="NUM">2</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="variables_set" id="after_set_skip_under">
                        <field name="VAR" id="v_skip_under_until">Skip Under Until</field>
                        <value name="VALUE">
                          <block type="math_arithmetic" id="after_set_skip_under_calc">
                            <field name="OP">ADD</field>
                            <value name="A">
                              <block type="variables_get" id="after_current_tick_for_under">
                                <field name="VAR" id="v_current_tick">Current Tick</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="after_skip_under_window">
                                <field name="NUM">30</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="after_reset_under_streak_after_skip">
                            <field name="VAR" id="v_under_loss_streak">Under Loss Streak</field>
                            <value name="VALUE">
                              <block type="math_number" id="after_reset_under_streak_after_skip_num">
                                <field name="NUM">0</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                  </block>
                </next>
              </block>
            </statement>
            <value name="IF1">
              <block type="logic_compare" id="after_loss_over_mode">
                <field name="OP">EQ</field>
                <value name="A">
                  <block type="variables_get" id="after_loss_mode_value_over">
                    <field name="VAR" id="v_current_mode">Current Mode</field>
                  </block>
                </value>
                <value name="B">
                  <block type="math_number" id="after_loss_over_num">
                    <field name="NUM">2</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO1">
              <block type="variables_set" id="after_increment_over_streak">
                <field name="VAR" id="v_over_loss_streak">Over Loss Streak</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="after_increment_over_streak_calc">
                    <field name="OP">ADD</field>
                    <value name="A">
                      <block type="variables_get" id="after_over_streak_get">
                        <field name="VAR" id="v_over_loss_streak">Over Loss Streak</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number" id="after_over_streak_inc">
                        <field name="NUM">1</field>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="controls_if" id="after_over_skip_check">
                    <value name="IF0">
                      <block type="logic_compare" id="after_over_streak_limit">
                        <field name="OP">GTE</field>
                        <value name="A">
                          <block type="variables_get" id="after_over_streak_limit_get">
                            <field name="VAR" id="v_over_loss_streak">Over Loss Streak</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="after_over_streak_limit_num">
                            <field name="NUM">2</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="variables_set" id="after_set_skip_over">
                        <field name="VAR" id="v_skip_over_until">Skip Over Until</field>
                        <value name="VALUE">
                          <block type="math_arithmetic" id="after_set_skip_over_calc">
                            <field name="OP">ADD</field>
                            <value name="A">
                              <block type="variables_get" id="after_current_tick_for_over">
                                <field name="VAR" id="v_current_tick">Current Tick</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="after_skip_over_window">
                                <field name="NUM">30</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="after_reset_over_streak_after_skip">
                            <field name="VAR" id="v_over_loss_streak">Over Loss Streak</field>
                            <value name="VALUE">
                              <block type="math_number" id="after_reset_over_streak_after_skip_num">
                                <field name="NUM">0</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </statement>
        <next>
          <block type="variables_set" id="after_reset_mode">
            <field name="VAR" id="v_current_mode">Current Mode</field>
            <value name="VALUE">
              <block type="math_number" id="after_reset_mode_num">
                <field name="NUM">0</field>
              </block>
            </value>
            <next>
              <block type="trade_again" id="after_trade_again"></block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="before_purchase_main" deletable="false" x="0" y="1020">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="variables_set" id="before_increment_tick">
        <field name="VAR" id="v_current_tick">Current Tick</field>
        <value name="VALUE">
          <block type="math_arithmetic" id="before_increment_tick_calc">
            <field name="OP">ADD</field>
            <value name="A">
              <block type="variables_get" id="before_current_tick_get">
                <field name="VAR" id="v_current_tick">Current Tick</field>
              </block>
            </value>
            <value name="B">
              <block type="math_number" id="before_increment_tick_num">
                <field name="NUM">1</field>
              </block>
            </value>
          </block>
        </value>
        <next>
          <block type="variables_set" id="before_set_stake">
            <field name="VAR" id="v_stake">Stake</field>
            <value name="VALUE">
              <block type="math_arithmetic" id="before_set_stake_calc">
                <field name="OP">MULTIPLY</field>
                <value name="A">
                  <block type="balance" id="before_balance_for_stake">
                    <field name="BALANCE_TYPE">NUM</field>
                  </block>
                </value>
                <value name="B">
                  <block type="variables_get" id="before_stake_pct_get">
                    <field name="VAR" id="v_stake_pct">Stake %</field>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <block type="variables_set" id="before_set_trigger_digit">
                <field name="VAR" id="v_trigger_digit">Trigger Digit</field>
                <value name="VALUE">
                  <block type="digit_frequency_analysis" id="before_most_frequent_digit">
                    <field name="RANK">most</field>
                    <value name="COUNT">
                      <shadow type="math_number" id="before_most_frequent_count_shadow">
                        <field name="NUM">100</field>
                      </shadow>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="controls_if" id="before_session_guard">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" elseif="5" else="1"></mutation>
                    <value name="IF0">
                      <block type="logic_compare" id="before_daily_loss_check">
                        <field name="OP">LTE</field>
                        <value name="A">
                          <block type="balance" id="before_balance_loss_check">
                            <field name="BALANCE_TYPE">NUM</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_arithmetic" id="before_daily_loss_limit_calc">
                            <field name="OP">MULTIPLY</field>
                            <value name="A">
                              <block type="variables_get" id="before_start_balance_get_loss">
                                <field name="VAR" id="v_start_balance">Start Balance</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_arithmetic" id="before_daily_loss_factor">
                                <field name="OP">MINUS</field>
                                <value name="A">
                                  <block type="math_number" id="before_daily_loss_factor_base">
                                    <field name="NUM">1</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="variables_get" id="before_loss_limit_get">
                                    <field name="VAR" id="v_loss_limit">Loss Limit %</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="notify" id="before_daily_loss_notify">
                        <field name="NOTIFICATION_TYPE">error</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <block type="text" id="before_daily_loss_text">
                            <field name="TEXT">Session stopped: daily loss limit reached.</field>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <value name="IF1">
                      <block type="logic_compare" id="before_daily_profit_check">
                        <field name="OP">GTE</field>
                        <value name="A">
                          <block type="balance" id="before_balance_profit_check">
                            <field name="BALANCE_TYPE">NUM</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_arithmetic" id="before_daily_profit_limit_calc">
                            <field name="OP">MULTIPLY</field>
                            <value name="A">
                              <block type="variables_get" id="before_start_balance_get_profit">
                                <field name="VAR" id="v_start_balance">Start Balance</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_arithmetic" id="before_daily_profit_factor">
                                <field name="OP">ADD</field>
                                <value name="A">
                                  <block type="math_number" id="before_daily_profit_factor_base">
                                    <field name="NUM">1</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="variables_get" id="before_profit_target_get">
                                    <field name="VAR" id="v_profit_target">Profit Target %</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO1">
                      <block type="notify" id="before_daily_profit_notify">
                        <field name="NOTIFICATION_TYPE">success</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <block type="text" id="before_daily_profit_text">
                            <field name="TEXT">Session stopped: profit target reached.</field>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <value name="IF2">
                      <block type="logic_compare" id="before_cooldown_check">
                        <field name="OP">GT</field>
                        <value name="A">
                          <block type="variables_get" id="before_cooldown_get">
                            <field name="VAR" id="v_cooldown">Cooldown</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="before_cooldown_zero">
                            <field name="NUM">0</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO2">
                      <block type="variables_set" id="before_reduce_cooldown">
                        <field name="VAR" id="v_cooldown">Cooldown</field>
                        <value name="VALUE">
                          <block type="math_arithmetic" id="before_reduce_cooldown_calc">
                            <field name="OP">MINUS</field>
                            <value name="A">
                              <block type="variables_get" id="before_cooldown_reduce_get">
                                <field name="VAR" id="v_cooldown">Cooldown</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="before_cooldown_reduce_num">
                                <field name="NUM">1</field>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <value name="IF3">
                      <block type="logic_compare" id="before_differs_signal_check">
                        <field name="OP">GTE</field>
